OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Tavily powers Pulse/webSearch server-side retrieval. Leave unset to answer
# without live source context in local development.
TAVILY_API_KEY=
# WEB_SEARCH_MAX_RESULTS=5

# Embeddings power uploaded-file knowledge retrieval. Defaults target OpenAI's
# text-embedding-3-small compatible /embeddings API.
OPENAI_API_KEY=
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small

# Fresh Neon Postgres database. DATABASE_URL is preferred.
DATABASE_URL=
# Optional accepted aliases:
# NEON_DATABASE_URL=
# POSTGRES_URL=

# Private file storage. Defaults to local development storage when unset.
# Supported providers: local, s3, r2.
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_BUCKET=zenquanta-files
FILE_STORAGE_LOCAL_DIR=.storage/zenquanta

# Required when FILE_STORAGE_PROVIDER is s3 or r2.
# FILE_STORAGE_ENDPOINT=
# FILE_STORAGE_REGION=auto
# FILE_STORAGE_ACCESS_KEY_ID=
# FILE_STORAGE_SECRET_ACCESS_KEY=

# Optional read-only GitHub App integration for Forge/project code context.
# The app should request Metadata: read and Contents: read permissions only.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CALLBACK_URL=
